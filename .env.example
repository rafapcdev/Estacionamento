# ──────────────────────────────────────────────────────────────
# Banco de dados PostgreSQL
# Formato: postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DBNAME
# ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://postgres:sua_senha@localhost:5432/parking_db

# Exibe SQL gerado pelo SQLAlchemy no console (true | false)
SQL_ECHO=false

# ──────────────────────────────────────────────────────────────
# Servidor
# ──────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
